<%
    let type = "post";
    if (is_home()) type = "index";
    if (is_post() || is_page()) type = "post";
    if (is_category() || page.type === "categories") type = "categories";
    if (is_tag() || page.type === "tags") type = "tags";
    if (is_archive()) type = "archives";
    let title = page.title + " | " + config.title;
    if (is_home()) title = config.title;
    if (is_post() || is_page()) title = page.title + " | " + config.title;
    if (is_category()) title = "Categories: " + page.category + " | " + config.title;
    if (is_tag()) title = "Tags: " + page.tag + " | " + config.title;
    if (is_archive()) title = "Archives | " + config.title;
%>
<!DOCTYPE html>
<html lang="<%- config.language %>">
<head>
    <script>
        const savedTheme = localStorage.getItem("theme");
        if (savedTheme) {
            document.documentElement.setAttribute("data-theme", savedTheme);
        }
        function updateHighlightStyle() {
            let currentTheme = document.documentElement.getAttribute("data-theme");
            if (!currentTheme) return;
            let lightStyle = document.getElementById("highlight-style-light");
            let darkStyle = document.getElementById("highlight-style-dark");
            if (lightStyle && darkStyle) {
                if (currentTheme === "dark") {
                    lightStyle.media = "none";
                    darkStyle.media = "all";
                } else {
                    lightStyle.media = "all";
                    darkStyle.media = "none";
                }
            }
        }
        window.addEventListener("DOMContentLoaded", updateHighlightStyle);
    </script>
    <meta charset="utf-8" />
    <title><%= title %></title>
    <meta name="author" content="<%- config.author %>" />
    <meta name="description" content="<%- config.description %>" />
    <meta name="keywords" content="<%- config.keywords %>" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="<%- url_for(theme.avatar) %>" />
    <%- partial("import", { type }) %>
</head>
<body>
    <div id="layout">
        <% if (theme.loading && theme.loading.enable) { %>
        <div id="loading" class="fade-transition" role="status" aria-label="页面加载中">
            <div id="loading-circle">
                <h2>LOADING</h2>
                <p>加载过慢请开启缓存 浏览器默认开启</p>
                <img src="<%- url_for(theme.loading.gif) %>" alt="loading" />
            </div>
        </div>
        <% } %>
        <%- partial("menu") %>
        <main id="main" class="<%- (theme.loading && theme.loading.enable) ? 'into-enter-active into-hidden' : 'into-enter-active' %>">
            <%- partial(type) %>
            <%- partial("footer") %>
        </main>
        <% if (theme.preview.enable) { %>
        <div id="preview" class="fade-transition fade-hidden">
            <img id="preview-content" alt="preview" />
        </div>
        <% } %>
    </div>
    <script src="<%- url_for("/js/main.js") %>" defer></script>
    <% if (type === "post" && page.comments) { %>
    <%- partial("comment") %>
    <% } %>
</body>
</html>
