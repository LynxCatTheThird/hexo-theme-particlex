<link rel="stylesheet" href="<%- url_for("/css/main.css") %>" />
<link rel="preconnect" href="https://s4.zstatic.net" />
<link rel="stylesheet" href="https://s4.zstatic.net/ajax/libs/font-awesome/6.4.2/css/all.min.css" media="print" onload="this.media='all'" />
<% if (theme.fonts && theme.fonts.enable) { %>
<link rel="preconnect" href="https://fonts.googleapis.cn" />
<link rel="preconnect" href="https://fonts.gstatic.cn" crossorigin />
<link rel="stylesheet" href="<%- theme.fonts.url %>" media="print" onload="this.media='all'" />
<noscript><link rel="stylesheet" href="<%- theme.fonts.url %>" /></noscript>
<style>
    :root {
        --font-family-sans: <%- theme.fonts.sans %>, -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", Arial, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
        --font-family-mono: <%- theme.fonts.mono %>, Menlo, Monaco, Consolas, "Courier New", monospace;
    }
</style>
<% } %>
<script>
    const theme_config = {
        loading_screen: <%- JSON.stringify(!!(theme.loading && theme.loading.enable)) %>,
        codeFoldThreshold: <%- JSON.stringify(theme.highlight && theme.highlight.foldThreshold !== undefined ? theme.highlight.foldThreshold : 40) %>
    };
</script>
<% if (theme.polyfill.enable) { %>
<script src="https://polyfill.alicdn.com/v3/polyfill.min.js?features=<%- theme.polyfill.features %>" defer></script>
<% } %>
<% if (theme.highlight.enable) { %>
<script src="https://s4.zstatic.net/ajax/libs/highlight.js/11.9.0/highlight.min.js" defer></script>
<script src="https://s4.zstatic.net/ajax/libs/highlightjs-line-numbers.js/2.8.0/highlightjs-line-numbers.min.js" defer></script>
<%
    let light_style = theme.highlight.style || "github";
    let dark_style = theme.highlight.dark_style || light_style + "-dark";
    if (dark_style === "github-dark-dark") dark_style = "github-dark";
%>
<link
    id="highlight-style-light"
    rel="stylesheet"
    href="https://s4.zstatic.net/ajax/libs/highlight.js/11.9.0/styles/<%- light_style %>.min.css"
    media="print" onload="this.media='(prefers-color-scheme: light)'"
/>
<link
    id="highlight-style-dark"
    rel="stylesheet"
    href="https://s4.zstatic.net/ajax/libs/highlight.js/11.9.0/styles/<%- dark_style %>.min.css"
    media="print" onload="this.media='(prefers-color-scheme: dark)'"
/>
<script src="<%- url_for("/js/lib/highlight.js") %>" defer></script>
<% } %>
<%
    let mathType = typeof theme.math === "string" ? theme.math : (theme.math && theme.math.type) ? theme.math.type : (theme.math && theme.math.enable) ? "katex" : false;
%>
<% if (mathType === "katex") { %>
<script src="https://s4.zstatic.net/ajax/libs/KaTeX/0.16.9/katex.min.js" defer></script>
<script src="https://s4.zstatic.net/ajax/libs/KaTeX/0.16.9/contrib/auto-render.min.js" defer></script>
<% if (theme.math && theme.math.katex && theme.math.katex.copy_tex) { %>
<script src="https://s4.zstatic.net/ajax/libs/KaTeX/0.16.9/contrib/copy-tex.min.js" defer></script>
<% } %>
<% if (theme.math && theme.math.katex && theme.math.katex.mhchem) { %>
<script src="https://s4.zstatic.net/ajax/libs/KaTeX/0.16.9/contrib/mhchem.min.js" defer></script>
<% } %>
<link rel="stylesheet" href="https://s4.zstatic.net/ajax/libs/KaTeX/0.16.9/katex.min.css" media="print" onload="this.media='all'" />
<script src="<%- url_for("/js/lib/math.js") %>" defer></script>
<% } else if (mathType === "mathjax") { %>
<script>
    window.MathJax = {
        tex: {
            inlineMath: [['$', '$'], ['\\(', '\\)']],
            displayMath: [['$$', '$$'], ['\\[', '\\]']],
            packages: {'[+]': [
                <%- (theme.math && theme.math.mathjax && theme.math.mathjax.mhchem) ? "'mhchem'" : "" %>
            ]}
        },
        <% if (theme.math && theme.math.mathjax && theme.math.mathjax.mhchem) { %>
        loader: {
            load: ['[tex]/mhchem']
        },
        <% } %>
        svg: {
            fontCache: 'global'
        }
    };
</script>
<script src="https://s4.zstatic.net/ajax/libs/mathjax/3.2.2/es5/tex-mml-chtml.min.js" defer></script>
<script src="<%- url_for("/js/lib/math.js") %>" defer></script>
<% } %>
<% if (theme.preview.enable) { %>
<script src="<%- url_for("/js/lib/preview.js") %>" defer></script>
<% } %>
<% if (theme.crypto.enable && typeof page.secret !== "undefined") { %>
<script src="https://s4.zstatic.net/ajax/libs/crypto-js/4.2.0/crypto-js.min.js" defer></script>
<script src="<%- url_for("/js/lib/crypto.js") %>" defer></script>
<% } %>
<% if (type === "archives" && theme.search.enable) { %>
<script src="<%- url_for("/js/lib/search.js") %>" defer></script>
<% } %>
<% if (type === "post" && page.comments) { %>
<% if (theme.gitalk.enable) { %>
<script src="https://s4.zstatic.net/ajax/libs/gitalk/1.8.0/gitalk.min.js" defer></script>
<link rel="stylesheet" href="https://s4.zstatic.net/ajax/libs/gitalk/1.8.0/gitalk.min.css" media="print" onload="this.media='all'" />
<% } %>
<% if (theme.waline.enable) { %>
<script src="https://s4.zstatic.net/ajax/libs/waline/2.15.8/waline.min.js" defer></script>
<link rel="stylesheet" href="https://s4.zstatic.net/ajax/libs/waline/2.15.8/waline.min.css" media="print" onload="this.media='all'" />
<link rel="stylesheet" href="https://s4.zstatic.net/ajax/libs/waline/2.15.8/waline-meta.min.css" media="print" onload="this.media='all'" />
<% } %>
<% if (theme.twikoo.enable) { %>
<script src="https://s4.zstatic.net/ajax/libs/twikoo/1.6.31/twikoo.all.min.js" defer></script>
<% } %>
<% } %>
<% if (type === "index") { %>
<script src="<%- url_for("/js/lib/home.js") %>" defer></script>
<% } %>
