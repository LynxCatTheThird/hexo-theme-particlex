<div class="article<%= (theme.toc && theme.toc.enable) ? ' has-toc' : '' %>">
    <div>
        <h1><%= page.title %></h1>
    </div>
    <div class="info">
        <span class="date">
            <span class="icon">
                <i class="fa-solid fa-calendar fa-fw"></i>
            </span>
            <%= date(page.date, "YYYY/M/D") %>
        </span>
        <% if (page.categories && page.categories.data.length !== 0) { %>
        <span class="category">
            <a href="<%- url_for(page.categories.data[0].path) %>">
                <span class="icon">
                    <i class="fa-solid fa-bookmark fa-fw"></i>
                </span>
                <%= page.categories.data[0].name %>
            </a>
        </span>
        <% } %>
        <% if (page.tags && page.tags.data.length !== 0) { %>
        <span class="tags">
            <span class="icon">
                <i class="fa-solid fa-tags fa-fw"></i>
            </span>
            <% let prev; %>
            <% page.tags.data.forEach((tag) => { %>
            <span class="tag">
                <%
                    const colors = theme.colors.filter((color) => color !== prev);
                    let id = Math.floor(Math.random() * colors.length);
                    prev = colors[id];
                %>
                <a href="<%- url_for(tag.path) %>" style="color: <%- colors[id] %>">
                    <%= tag.name %>
                </a>
            </span>
            <% }); %>
        </span>
        <% } %>
    </div>
    <% if (theme.crypto.enable && typeof page.secret !== "undefined") { %>
    <% const CryptoJS = getCryptoJS(); %>
    <input
        id="crypto"
        class="input"
        placeholder="文章被加密，请输入密码"
        data-encrypted="<%- CryptoJS.AES.encrypt(String(page.content || ''), String(page.secret)).toString() %>"
        data-shasum="<%- CryptoJS.SHA256(String(page.content || '')).toString() %>"
    />
    <div class="content fade-transition fade-hidden" id="crypto-content"></div>
    <% } else { %>
    <div class="content">
        <%- page.content %>
    </div>
    <% } %>
    <% if (page.comments) { %>
    <div id="comment">
        <% if (theme.gitalk.enable) { %>
        <div id="gitalk-container"></div>
        <% } %>
        <% if (theme.giscus.enable) { %>
        <div id="giscus-container" class="giscus"></div>
        <% } %>
        <% if (theme.waline.enable) { %>
        <div id="waline-container"></div>
        <% } %>
        <% if (theme.twikoo.enable) { %>
        <div id="twikoo-container"></div>
        <% } %>
    </div>
    <% } %>
</div>
<% if (theme.toc && theme.toc.enable) { %>
<nav id="toc" aria-label="目录">
    <div id="toc-inner">
        <div id="toc-resize"></div>
        <div id="toc-header">
            <span><i class="fa-solid fa-list-ul"></i>目录</span>
            <span id="toc-close"><i class="fa-solid fa-xmark"></i></span>
        </div>
        <div id="toc-scroll">
            <ul id="toc-list"></ul>
        </div>
        <div id="toc-footer">
            <% if (theme.toc.back_to_top !== false) { %>
            <button class="toc-footer-btn" id="toc-btn-top">
                <i class="fa-solid fa-arrow-up"></i>回到顶部
            </button>
            <% } %>
            <% if (theme.toc.go_to_comment !== false && page.comments) { %>
            <button class="toc-footer-btn" id="toc-btn-comment">
                <i class="fa-solid fa-comment"></i>前往评论
            </button>
            <% } %>
            <button class="toc-footer-btn" id="toc-btn-reading">
                <i class="fa-solid fa-book-open"></i>阅读模式
            </button>
        </div>
    </div>
</nav>
<button id="toc-toggle" aria-label="显示目录">
    <i class="fa-solid fa-list-ul"></i>
</button>
<button id="reading-mode-exit">
    <i class="fa-solid fa-xmark"></i>退出阅读模式
</button>
<% } %>

